{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valaiyagam.local/contracts/events/event-envelope.v1.schema.json",
  "title": "Valaiyagam Domain Event Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "producer",
    "correlation_id",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "minLength": 3
    },
    "event_version": {
      "type": "integer",
      "minimum": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 3
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": ["string", "null"]
    },
    "actor_id": {
      "type": ["string", "null"]
    },
    "payload": {
      "type": "object"
    }
  }
}
